{
  "version": 2,
  "routes": [
    { "src": "^/v1/home$", "dest": "/v1/index.html" },
    { "src": "^/v1/contact$", "dest": "/v1/contact.html" },
    { "src": "^/v1/links$", "dest": "/v1/links.html" },
    { "src": "^/v1/services$", "dest": "/v1/services.html" },
    { "src": "^/$", "dest": "/v1/index.html" },
    { "src": "^/home$", "dest": "/v1/index.html" },
    { "src": "^/contact$", "dest": "/v1/contact.html" },
    { "src": "^/links$", "dest": "/v1/links.html" },
    { "src": "^/services$", "dest": "/v1/services.html" },
    { "src": "^/images/(.*)$", "dest": "/images/$1" }
  ]
}
